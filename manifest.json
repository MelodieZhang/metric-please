{
  "manifest_version": 3,
  "name": "Metric Please",
  "version": "1.0.0",
  "description": "Auto-converts US/Imperial units to metric when you select text on any webpage.",
  "icons": {
    "16": "icons/icon-s.png",
    "48": "icons/icon-m.png",
    "128": "icons/icon-l.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-s.png",
    "default_title": "Metric Please"
  }
}
